# The Odds API — https://the-odds-api.com/ (free tier for dev)
ODDS_API_KEY=

# Optional stats provider key for live stat refreshes.
STATS_API_KEY=

# Optional: point the ML pipeline at a non-default config file.
BETTING_CONFIG_PATH=betting_system/config.yaml

# Optional: override DB path (default: data/dk_picks.db)
DK_PICKS_DB_PATH=data/dk_picks.db

# Default bankroll in dollars for sizing recommendations
DEFAULT_BANKROLL=500
